{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs the full test suite after each spec task is marked complete",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "npm test -- --run",
    "timeout": 120
  }
}